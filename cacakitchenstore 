<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CaCa Kitchen Store</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, sans-serif;
    }

    body{
      background:linear-gradient(135deg,#111,#222,#000);
      color:white;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:100vh;
      padding:20px;
    }

    .card{
      width:100%;
      max-width:420px;
      background:#1b1b1b;
      border-radius:25px;
      padding:30px;
      text-align:center;
      box-shadow:0 0 30px rgba(255,255,255,0.15);
      border:2px solid #444;
    }

    .logo{
      width:120px;
      height:120px;
      margin:auto;
      border-radius:50%;
      background:gold;
      display:flex;
      justify-content:center;
      align-items:center;
      font-size:34px;
      font-weight:bold;
      color:black;
      box-shadow:0 0 20px gold;
    }

    h1{
      margin-top:20px;
      font-size:30px;
      color:gold;
    }

    p{
      margin-top:10px;
      color:#ccc;
      font-size:15px;
    }

    .btn{
      display:block;
      width:100%;
      margin-top:18px;
      padding:15px;
      border-radius:15px;
      text-decoration:none;
      font-size:18px;
      font-weight:bold;
      transition:0.3s;
      color:white;
    }

    .whatsapp{
      background:#25D366;
    }

    .instagram{
      background:linear-gradient(45deg,#ff0066,#ff6600,#cc00ff);
    }

    .tiktok{
      background:#000;
      border:2px solid #fff;
    }

    .website{
      background:gold;
      color:black;
    }

    .btn:hover{
      transform:scale(1.05);
      box-shadow:0 0 20px rgba(255,255,255,0.4);
    }

    .footer{
      margin-top:25px;
      font-size:13px;
      color:#888;
    }
  </style>
</head>
<body>

  <div class="card">

    <div class="logo">CK</div>

    <h1>CaCa Kitchen Store</h1>

    <p>Premium Kitchen Products & Online Store</p>

    <a class="btn whatsapp" href="https://wa.me/923157301776" target="_blank">
      WhatsApp Chat
    </a>

    <a class="btn instagram" href="https://instagram.com/cacakitchenstore" target="_blank">
      Instagram
    </a>

    <a class="btn tiktok" href="https://tiktok.com/@cacakitchenstore" target="_blank">
      TikTok
    </a>

    <a class="btn website" href="#">
      Visit Website
    </a>

    <div class="footer">
      © 2026 CaCa Kitchen Store - All Rights Reserved
    </div>

  </div>

</body>
</html>